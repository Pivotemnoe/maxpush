generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  devices             Device[]
  pushSubscriptions   PushSubscription[]
  pairingSessions     PairingSession[]
  notificationEvents  NotificationEvent[]
}

model Device {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                String               // iphone_pwa | android_relay
  name                String?
  tokenHash           String?              @unique
  active              Boolean              @default(true)
  appVersion          String?
  lastSeenAt          DateTime?
  createdAt           DateTime             @default(now())
  notificationEvents  NotificationEvent[]

  @@index([userId, type])
}

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String   @unique
  p256dh      String
  auth        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, active])
}

model PairingSession {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model NotificationEvent {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  androidDeviceId String
  androidDevice   Device   @relation(fields: [androidDeviceId], references: [id], onDelete: Cascade)
  eventId         String   @unique
  sender          String?
  packageName     String
  privacyMode     String
  postedAt        DateTime
  createdAt       DateTime @default(now())
  deliveredAt     DateTime?

  @@index([userId, createdAt])
  @@index([androidDeviceId, createdAt])
}

model AdminCredential {
  id           String   @id @default("admin")
  username     String   @unique @default("admin")
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
